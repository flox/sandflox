#!/usr/bin/env bash
# sandflox entrypoint -- generated shell enforcement
# DO NOT EDIT; regenerated by sandflox on every invocation.

# ── Layer 2: requisites symlink bin ──────────────────────

_sfx_req="${FLOX_ENV_CACHE}/sandflox/requisites.txt"

if [ -f "$_sfx_req" ]; then
  _sfx_bin="${FLOX_ENV_CACHE}/sandflox/bin"
  # Use absolute paths from FLOX_ENV/bin for setup commands -- when
  # sourced by `sandflox elevate`, PATH may already be restricted to
  # the symlink bin and bare rm/mkdir/ln won't be found.
  "${FLOX_ENV}/bin/rm" -rf "$_sfx_bin"
  "${FLOX_ENV}/bin/mkdir" -p "$_sfx_bin"
  _sfx_count=0

  while IFS= read -r _sfx_line || [ -n "$_sfx_line" ]; do
    case "$_sfx_line" in \#*|"") continue ;; esac
    _sfx_tool="${_sfx_line%% *}"
    _sfx_tool="${_sfx_tool%%	*}"
    [ -z "$_sfx_tool" ] && continue
    if [ -x "${FLOX_ENV}/bin/$_sfx_tool" ]; then
      "${FLOX_ENV}/bin/ln" -sf "${FLOX_ENV}/bin/$_sfx_tool" "${_sfx_bin}/$_sfx_tool"
      _sfx_count=$((_sfx_count + 1))
    fi
  done < "$_sfx_req"

  # SHELL-09: auto-include sandflox binary for status/elevate inside sandbox
  if [ -x "${FLOX_ENV}/bin/sandflox" ]; then
    "${FLOX_ENV}/bin/ln" -sf "${FLOX_ENV}/bin/sandflox" "${_sfx_bin}/sandflox"
    _sfx_count=$((_sfx_count + 1))
  fi

  # SHELL-07: remove curl from bin when network is blocked
  if [ -f "${FLOX_ENV_CACHE}/sandflox/net-blocked.flag" ]; then
    if [ -L "${_sfx_bin}/curl" ]; then
      "${FLOX_ENV}/bin/rm" -f "${_sfx_bin}/curl"
      _sfx_count=$((_sfx_count - 1))
    fi
  fi

  # SHELL-01: PATH wipe -- only requisites-filtered bin
  export PATH="$_sfx_bin"
  # Ensure SANDFLOX_ENABLED is set for sandflox status/elevate detection
  export SANDFLOX_ENABLED=1
  _sfx_profile_name="default"
  [ -f "${FLOX_ENV_CACHE}/sandflox/active-profile.txt" ] && \
    read -r _sfx_profile_name < "${FLOX_ENV_CACHE}/sandflox/active-profile.txt" 2>/dev/null
  echo "[sandflox] Sandbox active: $_sfx_count tools (profile: $_sfx_profile_name)" >&2
fi

# ── Layer 3: Shell Function Armor ────────────────────────
# SHELL-03: shadow package manager commands with exit 126

_sandflox_blocked() {
  echo "[sandflox] BLOCKED: $1 is not available. Environment is immutable." >&2
  return 126
}

{{range .ArmoredCommands}}unalias {{.}} 2>/dev/null; {{.}}() { _sandflox_blocked {{.}}; }
{{end}}
export -f _sandflox_blocked {{range .ArmoredCommands}}{{.}} {{end}}

# ── Layer 5: Source fs-filter.sh (shell write enforcement) ──
# SHELL-04: generated by sandflox from policy.toml

if [ -f "${FLOX_ENV_CACHE}/sandflox/fs-filter.sh" ]; then
  . "${FLOX_ENV_CACHE}/sandflox/fs-filter.sh"
fi

# ── SHELL-05: Python enforcement env exports ─────────────

export PYTHON_NOPIP=1
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUSERBASE="${FLOX_ENV_CACHE}/sandflox-python"
export ENABLE_USER_SITE=1
export PYTHONPATH="${FLOX_ENV_CACHE}/sandflox-python:${PYTHONPATH:-}"

# ── Layer 4: Breadcrumb Cleanup ──────────────────────────
# SHELL-06: scrub env vars an agent could use to escape

unset FLOX_ENV_PROJECT FLOX_ENV_DIRS FLOX_PATH_PATCHED
unset _sfx_bin _sfx_req _sfx_count _sfx_line _sfx_tool _sfx_profile_name
